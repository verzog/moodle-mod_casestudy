{{!
    @template mod_casestudy/fields_page

    Fields management page for Case Study activity

    Context variables required for this template:
    * cmid - Course module ID
    * addFieldForm - Object with form data for adding fields
    * fieldsTable - Object with existing fields table data
    * hasFields - Boolean, whether fields exist
    * backUrl - URL to return to activity

    Example context (json):
    {
        "cmid": 123,
        "addFieldForm": {...},
        "fieldsTable": {...},
        "hasFields": true,
        "backUrl": "view.php?id=123"
    }
}}

{{> mod_casestudy/add_field_form }}

{{#hasfields}}
    {{{fieldstable}}}
{{/hasfields}}

{{^hasfields}}
<div class="alert alert-info">
    {{#str}}nofieldsyet, mod_casestudy{{/str}}
</div>
{{/hasfields}}

<div class="mt-3">
    <a href="{{{backurl}}}" class="btn btn-secondary">{{#str}}back{{/str}}</a>
    <a href="{{{previewurl}}}" class="btn btn-info" target="_blank"> {{#str}}preview, mod_casestudy{{/str}} </a>
</div>

