{{!
    @template mod_casestudy/submission

}}
{{! Submission information card }}
<div class="casestudy-submission-template">

    <div class="card mb-3 student-info-card">
        <div class="card-body">
            <h5 class="card-title">{{#str}}casestudyinfo, mod_casestudy{{/str}}</h5>
            <p>
                <strong>{{#str}}student, mod_casestudy{{/str}}:</strong> {{casestudyinfo.student}}
            </p>
            <p><strong>{{#str}}status{{/str}}:</strong>
                <span class="badge badge-{{casestudyinfo.statusclass}}">
                    {{casestudyinfo.statuslabel}}
                </span>
            </p>
            <p><strong>{{#str}}timecreated, mod_casestudy{{/str}}:</strong> {{casestudyinfo.timecreated}}</p>
            <p><strong>{{#str}}timemodified, mod_casestudy{{/str}}:</strong> {{casestudyinfo.timemodified}}</p>
        </div>
    </div>

    {{! Submission content card }}
    <div class="card mb-3 submission-content-card">
        <div class="card-body">
            <h5 class="card-title">{{#str}}casestudyuser, mod_casestudy, {{casestudyinfo.student}} {{/str}}</h5>

            <div class="casestudy-submission-content">
                {{#fields}}
                    <div class="field-display mt-2 field-{{type}}">
                        <div class="field-value">
                            {{#hasvalue}}
                                {{{value}}}
                            {{/hasvalue}}
                            {{^hasvalue}}
                                <em class="text-muted">{{#str}}novalue, mod_casestudy{{/str}}</em>
                            {{/hasvalue}}
                        </div>
                    </div>
                {{/fields}}
            </div>

        </div>
    </div>
</div>