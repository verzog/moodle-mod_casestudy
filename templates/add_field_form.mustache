{{!
    @template mod_casestudy/add_field_form

    Add field button with popover for Case Study field management

    Context variables required for this template:
    * cmid - Course module ID
    * fieldTypes - Array of available field types with icon
    * popoverContent - HTML content for the popover

    Example context (json):
    {
        "cmid": 123,
        "fieldTypes": [
            {"value": "text", "label": "Text", "icon": "font"},
            {"value": "textarea", "label": "Text area", "icon": "align-left"}
        ],
        "popoverContent": "<div>...</div>"
    }
}}

<div class="text-center mb-4">
    <button type="button"
            class="btn btn-primary btn-lg rounded-circle casestudy-add-field-btn"
            data-toggle="popover"
            data-placement="bottom"
            data-html="true"
            data-trigger="click"

            title="{{#str}}addfield, mod_casestudy{{/str}}"
            style="width: 60px; height: 60px; font-size: 24px;"
            data-container="body"

            >
        <i class="fa fa-plus"></i>
    </button>


    <div class="mt-2">
        <small class="text-muted">{{#str}}clicktoaddfield, mod_casestudy{{/str}}</small>
    </div>
</div>

<div id="field-type-popover" class="hide">
    <div class="popover-field-types list-group" >
    {{#fieldtypes}}
        <a href="{{{url}}}" class="list-group-item field-type-option"><i class="fa fa-{{icon}}"></i>{{label}}</a>
    {{/fieldtypes}}
    </div>
</div>

{{#js}}

require(['jquery', 'theme_boost/popover'], function($) {
    // Initialize the popover with the field types
    $('.casestudy-add-field-btn').popover({
        content: $('#field-type-popover').html(),
        html: true,
        placement: 'bottom',
        trigger: 'click',
        container: 'body',
    });

});
{{/js}}

