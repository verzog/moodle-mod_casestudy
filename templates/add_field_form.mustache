{{!
    @template mod_casestudy/add_field_form

    Add field button with popover for Case Study field management

    Context variables required for this template:
    * cmid - Course module ID
    * fieldTypes - Array of available field types with icon
    * popoverContent - HTML content for the popover

    Example context (json):
    {
        "cmid": 123,
        "fieldTypes": [
            {"value": "text", "label": "Text", "icon": "font"},
            {"value": "textarea", "label": "Text area", "icon": "align-left"}
        ],
        "popoverContent": "<div>...</div>"
    }
}}

<div class="text-center mb-4">
    <button type="button"
            class="btn btn-primary btn-lg rounded-circle casestudy-add-field-btn"
            title="{{#str}}addfield, mod_casestudy{{/str}}"
            style="width: 60px; height: 60px; font-size: 24px;"
            >
        <i class="fa fa-plus"></i>
    </button>


    <div class="mt-2">
        <small class="text-muted">{{#str}}clicktoaddfield, mod_casestudy{{/str}}</small>
    </div>
</div>

<div id="field-type-popover" class="hide">
    <div class="popover-field-types list-group" >
    {{#fieldtypes}}
        <a href="{{{url}}}" class="list-group-item field-type-option"><i class="fa fa-{{icon}}"></i>{{label}}</a>
    {{/fieldtypes}}
    </div>
</div>

{{#js}}
require(['theme_boost/popover'], function(PopoverModule) {
    // The theme_boost/popover module exports the Bootstrap 5 Popover class.
    var Popover = PopoverModule.Popover || PopoverModule.default || PopoverModule;
    var trigger = document.querySelector('.casestudy-add-field-btn');
    if (!trigger || !Popover) {
        return;
    }
    // Dispose any pre-existing instance so our config (content, sanitize) wins over the
    // empty-content popover theme_boost/loader may have already auto-attached.
    var existing = Popover.getInstance ? Popover.getInstance(trigger) : null;
    if (existing && typeof existing.dispose === 'function') {
        existing.dispose();
    }
    var contentNode = document.getElementById('field-type-popover');
    new Popover(trigger, {
        content: contentNode ? contentNode.innerHTML : '',
        html: true,
        placement: 'bottom',
        trigger: 'click',
        container: 'body',
        sanitize: false
    });
});
{{/js}}



