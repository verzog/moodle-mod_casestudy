{{!
    @template mod_casestudy/no_fields_message

    Message displayed when no fields are configured

    Context variables required for this template:
    * canmanage - Boolean, whether user can manage fields

    Example context (json):
    {
        "canmanage": true
    }
}}

{{#canmanage}}
<div class="alert alert-warning">
    {{#str}}nofields, mod_casestudy{{/str}}
</div>
{{/canmanage}}

{{^canmanage}}
<div class="alert alert-danger">
    {{#str}}notconfigured, mod_casestudy{{/str}}
</div>
{{/canmanage}}