    <h3>{{#str}}graderinterface, mod_casestudy{{/str}}</h3>
    <div class="mb-3">
        <a href="submission.php?id={{cmid}}" class="btn btn-primary">
            {{#str}}viewsubmissions, mod_casestudy{{/str}}
        </a>
    </div>
</div>